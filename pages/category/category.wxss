.page {
  display: flex;
  flex-direction: row;
  height: 100vh;
  font-family: "Microsoft YaHei";
  background-color: #f9f9f8;
}

.sidebar {
  width: 30%;
  background-color: #ffffff;
  border-right: 1px solid #e8e8e8;
  overflow-y: auto;
}

.cate-item {
  height: 50px;
  line-height: 50px;
  text-align: center;
  font-size: 14px;
  color: #333;
  border-bottom: 1px solid #f0f0f0;
}

.cate-item.active {
  color: #009966;
  background-color: #f9f9f8;
  font-weight: bold;
  border-left: 3px solid #009966;
}

.main {
  width: 70%;
  overflow-y: auto;
  padding: 10px;
}

.grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.goods-item {
  width: 45%;
  margin: 5px 2.5%;
  background-color: #ffffff;
  border-radius: 4px;
  padding: 8px;
  text-align: center;
}

.goods-item image {
  width: 100%;
  height: 120px;
}

.goods-name {
  font-size: 13px;
  color: #333;
  margin-top: 5px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  font-size: 15px;
  color: #ff0000;
  font-weight: bold;
  margin-top: 3px;
}

.empty {
  text-align: center;
  font-size: 14px;
  color: #999;
  margin-top: 100px;
}
